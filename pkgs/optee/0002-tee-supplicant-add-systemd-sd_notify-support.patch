 optee/optee_client/tee-supplicant/Makefile    |  3 +-
 .../tee-supplicant/src/sd_notify.c            | 93 +++++++++++++++++++
 .../tee-supplicant/src/sd_notify.h            | 11 +++
 .../tee-supplicant/src/tee_supplicant.c       |  6 ++
 5 files changed, 113 insertions(+), 1 deletion(-)
 create mode 100644 optee/optee_client/tee-supplicant/src/sd_notify.c
 create mode 100644 optee/optee_client/tee-supplicant/src/sd_notify.h

